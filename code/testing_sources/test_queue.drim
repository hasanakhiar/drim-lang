// Queue Test Script
q = queue_create()

wake("Enqueuing items: 10, 20, 30")
queue_enqueue(q, 10)
queue_enqueue(q, 20)
queue_enqueue(q, 30)

wake("Queue size: " + queue_size(q))
wake("Peek front: " + queue_peek(q))

wake("Dequeuing...")
val1 = queue_dequeue(q)
wake("Popped: " + val1)

wake("New front: " + queue_peek(q))
wake("Queue empty? " + queue_empty(q))

wake("Dequeuing remaining...")
queue_dequeue(q)
queue_dequeue(q)

wake("Final empty check: " + queue_empty(q))
