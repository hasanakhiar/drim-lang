// ===== DRIM LOOP TESTS =====

// --- TEST 1: Basic drimming (while) loop ---
wake("--- Test 1: Basic drimming loop ---")
i = 1
drimming i <= 5{
    wake(i)
    i = i + 1
}
// Expected: 1 2 3 4 5

// --- TEST 2: Multi-condition loop (and) ---
wake("--- Test 2: Multi-condition with 'and' ---")
i = 1 , j = 3
drimming i <= 10 and j <= 30{
    wake(i)
    wake(j)
    i = i + 1
    j = j + 3
}
// Expected: 1 3  2 6  3 9  4 12  5 15  6 18  7 21  8 24  9 27  10 30

// --- TEST 3: stopdrim (break) ---
wake("--- Test 3: stopdrim (break) ---")
i = 1
drimming i <= 100{
    if i == 4{
        wake("Breaking at 4")
        stopdrim
    }
    wake(i)
    i = i + 1
}
// Expected: 1 2 3 Breaking at 4

// --- TEST 4: drimagain (continue) ---
wake("--- Test 4: drimagain (continue) ---")
i = 0
drimming i < 10{
    i = i + 1
    if i % 2 == 0{
        drimagain
    }
    wake(i)
}
// Expected: 1 3 5 7 9 (skips even numbers)

// --- TEST 5: First multiple of 5 ---
wake("--- Test 5: First multiple of 5 ---")
i = 1
drimming i < 101{
    if i % 5 == 0{
        wake(i)
        stopdrim
    }
    i = i + 1
}
// Expected: 5

// --- TEST 6: Nested loops ---
wake("--- Test 6: Nested loops ---")
i = 1
drimming i <= 3{
    j = 1
    drimming j <= 3{
        wake(i * j)
        j = j + 1
    }
    i = i + 1
}
// Expected: 1 2 3  2 4 6  3 6 9

// --- TEST 7: stopdrim inside nested loop (only breaks inner) ---
wake("--- Test 7: Break inner loop ---")
i = 1
drimming i <= 3{
    j = 1
    drimming j <= 5{
        if j == 3{
            stopdrim
        }
        wake(i * 10 + j)
        j = j + 1
    }
    i = i + 1
}
// Expected: 11 12  21 22  31 32

// --- TEST 8: Countdown ---
wake("--- Test 8: Countdown ---")
n = 5
drimming n > 0{
    wake(n)
    n = n - 1
}
wake("Liftoff!")
// Expected: 5 4 3 2 1 Liftoff!

// --- TEST 9: Loop with string concatenation ---
wake("--- Test 9: String building ---")
msg = ""
i = 1
drimming i <= 5{
    msg = msg + "*"
    wake(msg)
    i = i + 1
}
// Expected: * ** *** **** *****

// --- TEST 10: Loop with 'or' condition ---
wake("--- Test 10: Loop with 'or' condition ---")
x = 1
drimming x < 3 or x == 5{
    wake(x)
    if x == 2{
        x = 5
    }
    else{
        x = x + 1
    }
}
// Expected: 1 2 5

// --- TEST 11: Comma-separated reset ---
wake("--- Test 11: Comma reset ---")
a = 100 , b = 200
wake(a)
wake(b)
// Expected: 100 200

wake("===== ALL LOOP TESTS DONE =====")