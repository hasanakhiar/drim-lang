func add(a, b) {
    return a + b
}

func say_hello(name) {
    wake("Hello, " + name + "!")
}

{
    func ret(N){
        return N
    }
    wake("Testing ret inside: " + ret(10))
}

wake("Testing ret OutSide: " + ret(22))

result = add(10, 20)
