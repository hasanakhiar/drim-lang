// Test for int64 and Stack DS

// 1. Test int64
// 2^62 should fit in long long (64-bit)
large_int = 4611686018427387904 
wake("Large int: ")
wake(large_int)

// 2. Test Stack DS
s = stack_create()
wake("Stack created. Size: ")
wake(stack_size(s))

wake("Pushing 10, 20, 30...")
stack_push(s, 10)
stack_push(s, 20)
stack_push(s, 30)

wake("Stack size after push: ")
wake(stack_size(s))

wake("Top element (peek): ")
wake(stack_peek(s))

wake("Popping elements...")
wake(stack_pop(s))
wake(stack_pop(s))

wake("Stack size after pop: ")
wake(stack_size(s))

wake("Is empty? ")
wake(stack_empty(s))

wake("Popping last element...")
wake(stack_pop(s))

wake("Is empty now? ")
wake(stack_empty(s))
